{
  "expo": {
    "name": "Dhamma School",
    "slug": "dhamma-school",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "dhamma-school",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5EFE6"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "org.mahamevnawa.dhamma-school",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to take student profile photos.",
        "NSPhotoLibraryUsageDescription": "Used to select student profile photos.",
        "NSPhotoLibraryAddUsageDescription": "Used to save photos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FAF6F0"
      },
      "package": "org.mahamevnawa.dhamma_school",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.RECORD_AUDIO"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#D4873A"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Dhamma School to access your photos for student profiles."
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.YOUR_IOS_CLIENT_ID"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "740c6911-dbe6-433b-a41b-980d65000093"
      },
      "router": {
        "origin": false
      }
    },
    "owner": "vinok88"
  }
}
